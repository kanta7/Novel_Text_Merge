# ── AI プロバイダ API キー ────────────────────────────────────────
# 使用するプロバイダのキーを設定してください（使わないものは省略可）

# Anthropic (Claude) - https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4o) - https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Google (Gemini) - https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=AIza...

# ── サーバー設定 ─────────────────────────────────────────────────
# Webサーバーポート (省略可、デフォルト: 3000)
# PORT=3000

# データディレクトリ (省略可、デフォルト: ./Novel_data)
# NOVEL_DATA_DIR=./Novel_data

# 出力ディレクトリ (省略可、デフォルト: ./output)
# NOVEL_OUTPUT_DIR=./output
